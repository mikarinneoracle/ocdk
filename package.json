{
  "name": "@mikarinneoracle/oci-cdk",
  "version": "1.1.0",
  "description": "OCI CDK stack for OCI Functions, API Gateway, and related infrastructure",
  "main": "lib/index.js",
  "bin": {
    "ocdk": "./bin/ocdk.js"
  },
  "scripts": {
    "build": "node bin/build-if-needed.js",
    "compile": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "ocdk": "node bin/ocdk.js",
    "cdktf": "cdktf",
    "deploy": "cdktf deploy",
    "diff": "cdktf diff",
    "destroy": "cdktf destroy",
    "get": "cdktf get",
    "synth": "cdktf synth",
    "list": "cdktf list",
    "prepublishOnly": "npm run get && npm run compile && npm run build && node -e \"var fs=require('fs'),path=require('path'),s='lib/config',d='config'; if(fs.existsSync(s)){if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(function(f){fs.copyFileSync(path.join(s,f),path.join(d,f));});}\""
  },
  "keywords": [
    "oci",
    "cdk",
    "terraform",
    "infrastructure-as-code"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikarinneoracle/ocdk.git"
  },
  "bugs": {
    "url": "https://github.com/mikarinneoracle/ocdk/issues"
  },
  "homepage": "https://github.com/mikarinneoracle/ocdk#readme",
  "readme": "README.md",
  "files": [
    "README.md",
    "bin",
    "lib",
    ".gen",
    "config",
    "cdktf.json",
    "ocdk.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "cdktf": "^0.21.0",
    "cdktf-cli": "^0.21.0",
    "constructs": "^10.0.0",
    "oci-common": "^2.120.0",
    "oci-objectstorage": "^2.120.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "uuid": "^9.0.0",
    "jssha": "^3.3.0",
    "glob": "^13.0.0"
  }
}
