{
  "name": "@mikarinneoracle/oci-cdk",
  "version": "1.0.0",
  "description": "OCI CDK stack for OCI Functions, API Gateway, and related infrastructure",
  "main": "lib/index.js",
  "bin": {
    "ocdk": "./bin/ocdk.js"
  },
  "scripts": {
    "build": "tsc",
    "compile": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "ocdk": "node bin/ocdk.js",
    "cdktf": "cdktf",
    "deploy": "cdktf deploy",
    "diff": "cdktf diff",
    "destroy": "cdktf destroy",
    "get": "cdktf get",
    "synth": "cdktf synth",
    "list": "cdktf list",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "oci",
    "cdk",
    "terraform",
    "infrastructure-as-code"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikarinneoracle/ocdk.git"
  },
  "bugs": { "url": "https://github.com/mikarinneoracle/ocdk/issues" },
  "homepage": "https://github.com/mikarinneoracle/ocdk#readme",
  "files": ["bin", "lib", "README.md", "cdktf.json", "ocdk.json"],
  "publishConfig": { "access": "public" },
  "dependencies": {
    "cdktf": "^0.21.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "cdktf-cli": "^0.21.0",
    "typescript": "^5.0.0"
  }
}
